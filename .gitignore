# Dependencies
node_modules/

# Python (bots/.venv is created by `npm run setup:python`)
.venv/
__pycache__/

# Cached Robocode jars (server/GUI, downloaded on first `npm run battle`/`gui`)
.robocode/

# Tournament runtime state (organizer machine only — do not commit)
scripts/tournament-state.json
recordings/

# Local schema-v2 runs, evaluation reports, and candidate checkpoints for
# alee-bot. Promotion is the only path from here to tracked champion artifacts.
bots/alee-bot/training/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
